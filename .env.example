# AI Down Detector — frontend Supabase config.
# Copy to .env.local and fill in from your Supabase project
# (Dashboard -> Project Settings -> API). These are public, anon-safe values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only — used by scripts/fetch-*.mjs to append snapshots to Supabase.
# Set these as GitHub Actions secrets (Settings -> Secrets and variables -> Actions),
# NOT in any committed file. The service-role key bypasses RLS; keep it secret.
# When unset (e.g. local dev), the fetchers just write the static /data files.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
