      "id": "snxm62gpxfc9",
      "name": "Connection failures for organizations restricting GitHub access by IP address",
      "status": "resolved",
      "impact": "major",
      "created_at": "2026-05-06T22:32:53.981Z",
      "started_at": "2026-05-06T22:32:53.974Z",
      "resolved_at": "2026-05-07T16:36:27.816Z",
      "components": [
        "claude.ai",
        "Claude Code"
      ],
      "keyword_match": true,
      "relevant_updates": [
        {
          "status": "identified",
          "created_at": "2026-05-06T22:32:54.098Z",
          "body": "We have identified an issue affecting organizations that restrict GitHub access by source IP address. A recent infrastructure change altered the IP addresses Anthropic uses for outbound connections to GitHub, which may cause Claude Code remote sessions, GitHub Enterprise plugin syncing, and Claude Security to fail. We are reverting the change to restore the previous IP ranges; no allowlist changes will be needed on your side. We will post an update once the fix is deployed."
        }
      ]
    },
